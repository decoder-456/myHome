<%- include('../partials/head') %>
</head>

<body class="min-h-screen bg-gradient-to-br from-purple-50 via-rose-50 to-orange-50">

<%- include('../partials/nav') %>

<!-- HERO -->
<section class="relative overflow-hidden">

  <!-- background glow -->
  <div class="absolute inset-0 bg-gradient-to-br from-purple-100 via-rose-100 to-orange-100 opacity-60"></div>

  <div class="container mx-auto max-w-5xl px-6 py-24 text-center relative z-10">

    <!-- badge -->
    <span class="inline-block text-xs font-semibold px-5 py-2 rounded-full mb-6 tracking-wide uppercase 
      bg-white/80 backdrop-blur border border-gray-200 text-gray-600 shadow-sm">
      ✨ Trusted by thousands of travellers
    </span>

    <!-- heading -->
    <h1 class="text-5xl sm:text-6xl font-extrabold text-gray-900 leading-tight mb-6">
      Find your next
      <br>
      <span class="bg-gradient-to-r from-purple-600 via-rose-500 to-orange-400 bg-clip-text text-transparent">
        perfect stay
      </span>
    </h1>

    <!-- subtitle -->
    <p class="text-gray-500 text-lg sm:text-xl mb-10 max-w-xl mx-auto">
      Discover unique homes — from cozy cabins to luxury villas across the world.
    </p>

    <!-- buttons -->
    <% if (!isLoggedIn) { %>
      <div class="flex justify-center gap-4 flex-wrap">

        <a href="/signup"
          class="px-8 py-3.5 rounded-xl text-white font-semibold shadow-lg 
          bg-gradient-to-r from-purple-500 to-rose-500 hover:opacity-90 transition">
          Get Started Free
        </a>

        <a href="/login"
          class="px-8 py-3.5 rounded-xl bg-white border border-gray-200 text-gray-700 
          hover:bg-gray-50 transition shadow-sm">
          Log In
        </a>

      </div>
    <% } else { %>

      <a href="/explore"
        class="inline-block px-10 py-3.5 rounded-xl text-white font-semibold shadow-lg 
        bg-gradient-to-r from-purple-500 to-rose-500 hover:opacity-90 transition">
        Explore Homes →
      </a>

    <% } %>

  </div>

  <!-- floating blobs -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-purple-300 opacity-20 blur-3xl rounded-full"></div>
  <div class="absolute bottom-0 left-0 w-80 h-80 bg-rose-300 opacity-20 blur-3xl rounded-full"></div>

</section>

<!-- STATS -->
<% if (!isLoggedIn) { %>
<div class="py-10 bg-white/70 backdrop-blur border-y border-gray-100">
  <div class="container mx-auto flex justify-center gap-16 text-center flex-wrap">

    <div>
      <p class="text-3xl font-bold text-purple-600"><%= homes.length %>+</p>
      <p class="text-sm text-gray-400">Homes listed</p>
    </div>

    <div>
      <p class="text-3xl font-bold text-rose-500">100%</p>
      <p class="text-sm text-gray-400">Verified hosts</p>
    </div>

    <div>
      <p class="text-3xl font-bold text-orange-400">24/7</p>
      <p class="text-sm text-gray-400">Support</p>
    </div>

  </div>
</div>
<% } %>

<!-- HOMES -->
<section class="container mx-auto px-6 py-16 max-w-7xl">

  <div class="flex justify-between items-end mb-10">
    <div>
      <h2 class="text-3xl font-bold text-gray-900">Featured Homes</h2>
      <p class="text-gray-400 text-sm mt-1">Hand-picked stays for you</p>
    </div>
  </div>

  <% if (homes.length === 0) { %>

    <div class="text-center py-24">
      <p class="text-7xl mb-5">🏚️</p>
      <p class="text-xl text-gray-400">No homes listed yet</p>
    </div>

  <% } else { %>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">

    <% homes.forEach(home => { %>

    <a href="<%= isLoggedIn ? '/store/home/' + home._id : '/login' %>" class="group">

      <div class="bg-white/80 backdrop-blur-lg rounded-3xl overflow-hidden shadow-md border border-gray-100 
                  hover:shadow-2xl transition-all duration-300 hover:-translate-y-2">

        <!-- image -->
        <div class="relative h-56 overflow-hidden">
          <img src="<%= home.photoUrl %>"
            class="w-full h-full object-cover group-hover:scale-110 transition duration-500">

          <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>

          <span class="absolute top-3 right-3 bg-white/90 text-amber-500 text-xs font-semibold px-3 py-1 rounded-full shadow">
            ⭐ <%= home.rating %>
          </span>

        </div>

        <!-- content -->
        <div class="p-5">

          <h3 class="text-lg font-semibold text-gray-800 group-hover:text-purple-600 transition">
            <%= home.houseName %>
          </h3>

          <p class="text-gray-400 text-sm mt-1">
            📍 <%= home.location %>
          </p>

          <p class="mt-3 text-lg font-bold text-purple-600">
            ₹<%= home.price %>
            <span class="text-gray-400 text-sm font-normal">/ night</span>
          </p>

        </div>

      </div>

    </a>

    <% }) %>

  </div>

  <% } %>

</section>

<!-- CTA -->
<% if (!isLoggedIn) { %>
<section class="mx-6 mb-16 rounded-3xl py-16 px-8 text-center shadow-2xl text-white relative overflow-hidden
  bg-gradient-to-r from-purple-500 via-rose-500 to-orange-400">

  <h2 class="text-3xl font-bold mb-3">
    Ready to find your dream stay?
  </h2>

  <p class="text-white/80 mb-8">
    Join thousands of users exploring unique homes every day.
  </p>

  <a href="/signup"
    class="inline-block bg-white text-purple-600 px-8 py-3 rounded-xl font-semibold shadow hover:bg-gray-100 transition">
    Sign Up Free
  </a>

</section>
<% } %>

</body>
</html>