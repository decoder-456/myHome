<%- include('../partials/head') %>
</head>

<body class="bg-white">
<%- include('../partials/nav') %>

<!-- Hero -->
<section class="relative overflow-hidden" style="background: linear-gradient(135deg, #fff1f2 0%, #fff7ed 60%, #fefce8 100%);">
  <div class="container mx-auto max-w-4xl px-6 py-20 text-center relative z-10">
    <span class="inline-block text-xs font-semibold px-4 py-1.5 rounded-full mb-6 tracking-widest uppercase border"
      style="background:#fff0f3; color:#e11d48; border-color:#fecdd3; letter-spacing:0.1em;">
      🏡 Trusted by thousands of travellers
    </span>
    <h1 class="text-5xl sm:text-6xl font-extrabold text-gray-900 mb-5 leading-tight">
      Find your next<br>
      <span style="background: linear-gradient(90deg,#e11d48,#f97316); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">
        perfect stay
      </span>
    </h1>
    <p class="text-gray-500 text-lg sm:text-xl mb-10 max-w-lg mx-auto leading-relaxed">
      Discover unique homes and experiences — from cozy cottages to luxury villas.
    </p>
    <% if (!isLoggedIn) { %>
      <div class="flex justify-center gap-3 flex-wrap">
        <a href="/signup"
          class="text-white px-8 py-3.5 rounded-2xl font-semibold text-base shadow-lg hover:opacity-90 transition"
          style="background: linear-gradient(135deg,#e11d48,#f97316);">
          Get Started — It's Free
        </a>
        <a href="/login"
          class="border-2 border-gray-200 hover:border-gray-300 text-gray-700 px-8 py-3.5 rounded-2xl font-semibold text-base transition hover:bg-gray-50 bg-white">
          Log In
        </a>
      </div>
    <% } else { %>
      <a href="/explore"
        class="inline-block text-white px-10 py-3.5 rounded-2xl font-semibold text-base shadow-lg hover:opacity-90 transition"
        style="background: linear-gradient(135deg,#e11d48,#f97316);">
        Explore Homes →
      </a>
    <% } %>
  </div>
  <!-- Decorative blobs -->
  <div class="absolute top-0 right-0 w-96 h-96 rounded-full opacity-20 blur-3xl pointer-events-none" style="background:#fda4af; transform: translate(30%, -30%);"></div>
  <div class="absolute bottom-0 left-0 w-80 h-80 rounded-full opacity-15 blur-3xl pointer-events-none" style="background:#fdba74; transform: translate(-30%, 30%);"></div>
</section>

<!-- Stats Bar -->
<% if (!isLoggedIn) { %>
<div class="border-y border-gray-100 bg-white py-8">
  <div class="container mx-auto px-6 flex justify-center gap-12 sm:gap-20 flex-wrap text-center">
    <div>
      <p class="text-3xl font-extrabold text-rose-500"><%= homes.length %>+</p>
      <p class="text-sm text-gray-400 mt-1">Homes listed</p>
    </div>
    <div>
      <p class="text-3xl font-extrabold text-orange-400">100%</p>
      <p class="text-sm text-gray-400 mt-1">Verified hosts</p>
    </div>
    <div>
      <p class="text-3xl font-extrabold text-amber-500">24/7</p>
      <p class="text-sm text-gray-400 mt-1">Support</p>
    </div>
  </div>
</div>
<% } %>

<!-- Featured Homes -->
<section class="container mx-auto px-6 py-16 max-w-7xl">
  <div class="flex justify-between items-end mb-8">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">Featured Homes</h2>
      <p class="text-gray-400 text-sm mt-1">Hand-picked stays for every traveller</p>
    </div>
    <% if (!isLoggedIn) { %>
      <a href="/signup" class="text-sm text-rose-500 hover:underline font-medium hidden sm:block">
        Sign up to save & book →
      </a>
    <% } %>
  </div>

  <% if (homes.length === 0) { %>
    <div class="text-center py-24">
      <p class="text-7xl mb-5">🏚️</p>
      <p class="text-xl font-medium text-gray-400">No homes listed yet</p>
    </div>
  <% } else { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <% homes.forEach(home => { %>
        <a href="<%= isLoggedIn ? '/store/home/' + home._id : '/login' %>" class="group block">
          <div class="bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="relative h-52 overflow-hidden">
              <img src="<%= home.photoUrl %>" alt="<%= home.houseName %>"
                class="w-full h-full object-cover group-hover:scale-105 transition duration-500">
              <% if (!isLoggedIn) { %>
                <div class="absolute inset-0 bg-black/10 flex items-center justify-center opacity-0 group-hover:opacity-100 transition">
                  <span class="bg-white text-gray-800 text-xs font-semibold px-3 py-1.5 rounded-full shadow">🔒 Login to view</span>
                </div>
              <% } %>
              <span class="absolute top-3 right-3 bg-white/95 text-amber-500 text-xs font-bold px-2.5 py-1 rounded-full shadow-sm">
                ⭐ <%= home.rating %>
              </span>
            </div>
            <div class="p-4">
              <h3 class="text-sm font-semibold text-gray-900 truncate mb-1"><%= home.houseName %></h3>
              <p class="text-gray-400 text-xs mb-3 truncate">📍 <%= home.location %></p>
              <p class="text-sm font-bold text-gray-900">
                ₹<%= home.price %> <span class="font-normal text-gray-400 text-xs">/ night</span>
              </p>
            </div>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>
</section>

<!-- CTA Banner -->
<% if (!isLoggedIn) { %>
<section class="mx-4 sm:mx-6 mb-16 rounded-3xl text-white py-16 px-8 text-center shadow-xl relative overflow-hidden"
  style="background: linear-gradient(135deg, #e11d48 0%, #f97316 100%);">
  <div class="absolute top-6 left-10 text-5xl opacity-20 select-none pointer-events-none">🏠</div>
  <div class="absolute bottom-6 right-10 text-5xl opacity-20 select-none pointer-events-none">🌴</div>
  <div class="relative z-10 max-w-lg mx-auto">
    <h2 class="text-3xl font-bold mb-3">Ready to find your perfect home?</h2>
    <p class="text-rose-100 mb-8 text-base">
      Join thousands of travellers discovering unique stays on MyHome every day.
    </p>
    <a href="/signup"
      class="inline-block bg-white text-rose-600 hover:bg-rose-50 px-8 py-3 rounded-2xl font-semibold transition shadow-md">
      Sign Up for Free
    </a>
  </div>
</section>
<% } %>

</body>
</html>
