<%- include('../partials/head') %>
</head>

<body class="min-h-screen bg-gradient-to-br from-purple-50 via-rose-50 to-orange-50">

<%- include('../partials/nav') %>

<!-- HERO -->
<div class="relative w-full h-[60vh] overflow-hidden">
  <img src="<%= home.photoUrl %>" 
       class="w-full h-full object-cover scale-105">

  <!-- overlay -->
  <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>

  <!-- Back -->
   <% if(userType!='host'){%>
  <a href="/explore"
    class="absolute top-6 left-6 bg-white/80 backdrop-blur-md px-4 py-2 rounded-full text-sm font-medium shadow hover:bg-white transition">
    ← Back
  </a>
   <%}%>
  <!-- Title -->
  <div class="absolute bottom-8 left-6 right-6 max-w-5xl mx-auto text-white">
    <h1 class="text-4xl font-bold mb-2 drop-shadow-lg">
      <%= home.houseName %>
    </h1>

    <div class="flex items-center gap-3 text-sm text-white/90">
      <span>⭐ <strong><%= home.rating %></strong></span>
      <span class="opacity-40">·</span>
      <span>📍 <%= home.location %></span>
    </div>
  </div>
</div>

<main class="container mx-auto px-6 py-12 max-w-6xl">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

    <!-- LEFT -->
    <div class="md:col-span-2 space-y-8">

      <!-- STATS -->
      <div class="grid grid-cols-3 gap-4">

        <div class="bg-white/80 backdrop-blur-lg rounded-2xl p-5 text-center shadow border border-gray-100">
          <p class="text-2xl mb-1">📍</p>
          <p class="text-xs text-gray-400 uppercase">Location</p>
          <p class="text-sm font-semibold text-gray-800 truncate">
            <%= home.location %>
          </p>
        </div>

        <div class="bg-white/80 backdrop-blur-lg rounded-2xl p-5 text-center shadow border border-gray-100">
          <p class="text-2xl mb-1">⭐</p>
          <p class="text-xs text-gray-400 uppercase">Rating</p>
          <p class="text-sm font-semibold text-gray-800">
            <%= home.rating %> / 5
          </p>
        </div>

        <div class="bg-white/80 backdrop-blur-lg rounded-2xl p-5 text-center shadow border border-gray-100">
          <p class="text-2xl mb-1">💰</p>
          <p class="text-xs text-gray-400 uppercase">Price</p>
          <p class="text-sm font-semibold text-purple-600">
            ₹<%= home.price %>
          </p>
        </div>

      </div>

      <!-- DESCRIPTION -->
      <div class="bg-white/80 backdrop-blur-lg rounded-3xl p-6 shadow-lg border border-gray-100">
        <h2 class="text-lg font-semibold text-gray-900 mb-3">
          About this place
        </h2>

        <% if (home.description) { %>
          <p class="text-gray-600 leading-relaxed text-sm">
            <%= home.description %>
          </p>
        <% } else { %>
          <p class="text-gray-400 italic text-sm">
            No description provided.
          </p>
        <% } %>
      </div>

      <!-- AMENITIES -->
      <div class="bg-white/80 backdrop-blur-lg rounded-3xl p-6 shadow-lg border border-gray-100">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">
          What this place offers
        </h2>

        <div class="grid grid-cols-2 gap-3">
          <% [['🛜','Free WiFi'],['🅿️','Parking'],['❄️','AC'],['🍳','Kitchen'],['🧺','Washer'],['📺','TV']].forEach(([icon,label]) => { %>
            <div class="flex items-center gap-3 text-sm bg-gray-50 rounded-xl px-3 py-2">
              <span><%= icon %></span>
              <span class="text-gray-600"><%= label %></span>
            </div>
          <% }) %>
        </div>
      </div>

    </div>

    <!-- RIGHT (BOOKING CARD) -->
    <div>
      <div class="bg-white/90 backdrop-blur-xl rounded-3xl p-6 shadow-2xl border border-gray-100 sticky top-24">

        <!-- Price -->
        <p class="text-3xl font-bold text-gray-900 mb-2">
          ₹<%= home.price %>
          <span class="text-sm text-gray-400">/ night</span>
        </p>

        <div class="flex items-center gap-2 mb-5">
          <span class="text-amber-400">⭐</span>
          <span class="font-semibold text-gray-700 text-sm">
            <%= home.rating %>
          </span>
        </div>

        <!-- Dates -->
            <% if (userType === 'guest') { %>  
        <div class="border rounded-2xl overflow-hidden mb-4">
          <div class="grid grid-cols-2 divide-x">
            <input type="date" class="p-3 text-sm outline-none">
            <input type="date" class="p-3 text-sm outline-none">
          </div>
        </div>

        <!-- Reserve -->
        <button class="w-full py-3 rounded-xl text-white font-semibold mb-3 shadow-md hover:opacity-90"
          style="background: linear-gradient(135deg,#8b5cf6,#f43f5e);">
          Reserve Now
        </button>

        <!-- Favourite -->
        <form action="/favourite" method="POST">
          <input type="hidden" name="homeId" value="<%= home._id %>">

          <button class="w-full py-3 rounded-xl border border-rose-200 text-rose-500 hover:bg-rose-50 transition">
            ❤️ Save to Favourites
          </button>
        </form>

        <p class="text-xs text-gray-400 text-center mt-4">
          You won't be charged yet
        </p>
  <% } %>
      </div>
    </div>

  </div>
</main>

</body>
</html>