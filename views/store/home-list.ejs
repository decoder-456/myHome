<%- include('../partials/head') %>
</head>

<body class="bg-gray-100">

<%- include('../partials/nav') %>

<main class="container mx-auto px-6 py-10">

  <h2 class="text-3xl font-bold text-center text-red-500 mb-10">
    🏡 Here are your homes
  </h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">

    <% homes.forEach(home => { %>

      <div class="relative group">

        <!-- Favourite Button (OUTSIDE LINK) -->
        <form action="/favourite" method="POST" class="absolute top-3 right-3 z-10">
          <input type="hidden" name="homeId" value="<%= home._id %>">
          <button 
            type="submit"
            onclick="event.stopPropagation()"
            class="bg-white p-2 rounded-full shadow hover:bg-red-100 transition text-lg hover:scale-110 duration-200">
                ❤️
          </button>
        </form>

        <!-- Clickable Card -->
        <a href="/store/home/<%= home._id %>">

          <div class="bg-white rounded-xl shadow-md overflow-hidden 
          hover:shadow-xl transition duration-300 transform hover:-translate-y-1">

            <!-- Image -->
            <img 
              src="https://images.unsplash.com/photo-1564013799919-ab600027ffc6"
              class="w-full h-52 object-cover">

            <!-- Card Content -->
            <div class="p-5">

              <h3 class="text-xl font-semibold text-gray-800 mb-2 group-hover:text-red-500 transition">
                <%= home.houseName %>
              </h3>

              <p class="text-gray-500 text-sm mb-3">
                📍 <%= home.location %>
              </p>

              <div class="flex justify-between items-center">

                <!-- Price -->
                <span class="text-lg font-bold text-red-500">
                  ₹<%= home.price %> 
                  <span class="text-gray-400 text-sm">/ night</span>
                </span>

                <!-- Rating -->
                <div class="flex items-center text-yellow-400 font-semibold">
                  ⭐ <span class="text-gray-700 ml-1"><%= home.rating %></span>
                </div>

              </div>

            </div>

          </div>

        </a>

      </div>

    <% }) %>

  </div>

</main>

</body>
</html>