<%- include('../partials/head') %>
</head>

<body class="min-h-screen bg-gradient-to-br from-purple-50 via-rose-50 to-orange-50">

<%- include('../partials/nav') %>

<main class="container mx-auto px-6 py-12">

  <!-- Heading -->
  <div class="text-center mb-12">
    <h2 class="text-4xl font-bold text-gray-900">
      🏡 Explore Homes
    </h2>
    <p class="text-gray-500 text-sm mt-2">
      Find your perfect stay
    </p>
  </div>

  <!-- Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10">

    <% homes.forEach(home => { %>

      <div class="relative group">

        <!-- ❤️ Favourite -->
        <form action="/favourite" method="POST" 
              class="absolute top-3 right-3 z-10">
          <input type="hidden" name="homeId" value="<%= home._id %>">
          
          <button 
            type="submit"
            onclick="event.stopPropagation()"
            class="bg-white/90 backdrop-blur-md p-2.5 rounded-full shadow-md 
                   hover:bg-rose-50 hover:scale-110 transition-all duration-200 text-rose-500">
            ❤️
          </button>
        </form>

        <!-- Card -->
        <a href="/store/home/<%= home._id %>">

          <div class="bg-white/80 backdrop-blur-lg rounded-3xl shadow-lg border border-gray-100 overflow-hidden
                      hover:shadow-2xl transition duration-300 transform hover:-translate-y-2">

            <!-- Image -->
            <div class="relative overflow-hidden h-56">
              <img 
                src="<%= home.photoUrl || 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6' %>"
                class="w-full h-full object-cover group-hover:scale-110 transition duration-500">

              <!-- overlay -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
            </div>

            <!-- Content -->
            <div class="p-5">

              <h3 class="text-lg font-semibold text-gray-800 mb-2 group-hover:text-purple-600 transition">
                <%= home.houseName %>
              </h3>

              <p class="text-gray-500 text-sm mb-3">
                📍 <%= home.location %>
              </p>

              <div class="flex justify-between items-center">

                <!-- Price -->
                <span class="text-lg font-bold text-purple-600">
                  ₹<%= home.price %>
                  <span class="text-gray-400 text-sm">/ night</span>
                </span>

                <!-- Rating -->
                <div class="flex items-center text-yellow-400 font-semibold text-sm">
                  ⭐ <span class="text-gray-700 ml-1"><%= home.rating %></span>
                </div>

              </div>

            </div>

          </div>

        </a>

      </div>

    <% }) %>

  </div>

  <!-- Empty state -->
  <% if (homes.length === 0) { %>
    <div class="text-center mt-16">
      <p class="text-gray-400 text-lg">No homes available</p>
      <a href="/explore"
        class="inline-block mt-4 px-6 py-3 rounded-xl bg-gradient-to-r from-purple-500 to-rose-500 text-white font-semibold shadow hover:opacity-90 transition">
        Explore homes
      </a>
    </div>
  <% } %>

</main>

</body>
</html>