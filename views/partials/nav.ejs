<header class="fixed top-0 left-0 w-full z-50 bg-white/80 backdrop-blur-md border-b border-gray-100 shadow-sm">
  
  <nav class="container mx-auto flex justify-between items-center px-6 h-16">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 text-transparent bg-clip-text bg-gradient-to-r from-purple-600 via-rose-500 to-orange-400 font-extrabold text-xl tracking-tight">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 fill-purple-500" viewBox="0 0 24 24">
        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/>
      </svg>
      MyHome
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden md:flex items-center gap-2 text-sm font-medium text-gray-600">

      <% if (isLoggedIn) { %>

        <% if (userType === 'guest') { %>
          <li>
            <a href="/explore"
              class="px-4 py-2 rounded-xl transition <%= currentPage==='explore' ? 'bg-purple-100 text-purple-600 font-semibold' : 'hover:bg-gray-100' %>">
              Explore
            </a>
          </li>

          <li>
            <a href="/store/favourite-home"
              class="px-4 py-2 rounded-xl transition <%= currentPage==='favourite' ? 'bg-purple-100 text-purple-600 font-semibold' : 'hover:bg-gray-100' %>">
              ❤️ Saved
            </a>
          </li>

          <li>
            <a href="/store/home-booking"
              class="px-4 py-2 rounded-xl transition <%= currentPage==='bookingHome' ? 'bg-purple-100 text-purple-600 font-semibold' : 'hover:bg-gray-100' %>">
              Bookings
            </a>
          </li>
        <% } %>

        <% if (userType === 'host') { %>
          <li>
            <a href="/host/home-list"
              class="px-4 py-2 rounded-xl transition <%= currentPage==='homeList' ? 'bg-purple-100 text-purple-600 font-semibold' : 'hover:bg-gray-100' %>">
              My Listings
            </a>
          </li>

          <li>
            <a href="/host/add-home"
              class="ml-1 px-4 py-2 rounded-xl text-white font-semibold bg-gradient-to-r from-purple-500 to-rose-500 hover:opacity-90 transition shadow">
              + List Home
            </a>
          </li>
        <% } %>

        <!-- User -->
        <li class="ml-3 pl-3 border-l border-gray-200 relative" id="userMenuWrapper">
          <button id="userMenuBtn"
            class="flex items-center gap-2 bg-gray-50 hover:bg-gray-100 border border-gray-200 rounded-full px-3 py-1.5 transition">

            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-500 to-rose-500 flex items-center justify-center text-white text-xs font-bold uppercase">
              <%= userName ? userName[0] : 'U' %>
            </div>

            <span class="text-gray-700 text-sm font-medium"><%= userName %></span>

            <svg xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5 text-gray-400 transition-transform"
              id="dropChevron"
              fill="none" stroke="currentColor" stroke-width="2.5"
              viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>

          <!-- Dropdown -->
          <div id="userDropdown"
            class="hidden absolute right-0 mt-2 w-52 bg-white rounded-2xl shadow-xl border border-gray-100 py-2">

            <div class="px-4 py-3 border-b border-gray-100">
              <p class="text-sm font-semibold text-gray-800"><%= userName %></p>
              <p class="text-xs text-gray-400 capitalize"><%= userType %> account</p>
            </div>

            <% if (userType === 'guest') { %>
              <a href="/explore" class="block px-4 py-2 hover:bg-gray-50">🔍 Explore</a>
              <a href="/store/favourite-home" class="block px-4 py-2 hover:bg-gray-50">❤️ Saved</a>
              <a href="/store/home-booking" class="block px-4 py-2 hover:bg-gray-50">📋 Bookings</a>
            <% } %>

            <% if (userType === 'host') { %>
              <a href="/host/home-list" class="block px-4 py-2 hover:bg-gray-50">🏠 Listings</a>
              <a href="/host/add-home" class="block px-4 py-2 hover:bg-gray-50">➕ Add Home</a>
            <% } %>

            <div class="border-t mt-2 pt-2">
              <form action="/logout" method="POST">
                <button class="w-full text-left px-4 py-2 text-rose-500 hover:bg-rose-50">
                  🚪 Logout
                </button>
              </form>
            </div>

          </div>
        </li>

      <% } else { %>

        <li>
          <a href="/" class="px-4 py-2 rounded-xl hover:bg-gray-100">Home</a>
        </li>

        <li>
          <a href="/login"
            class="px-4 py-2 rounded-xl border border-gray-200 hover:border-gray-300 transition">
            Login
          </a>
        </li>

        <li>
          <a href="/signup"
            class="px-4 py-2 rounded-xl text-white bg-gradient-to-r from-purple-500 to-rose-500 hover:opacity-90 transition shadow">
            Sign up
          </a>
        </li>

      <% } %>

    </ul>

    <!-- Mobile -->
    <button id="menuBtn" class="md:hidden p-2 rounded-xl hover:bg-gray-100">
      ☰
    </button>

  </nav>

  <!-- Mobile Menu -->
  <div id="mobileMenu"
    class="hidden md:hidden bg-white border-t border-gray-100 px-6 py-4 space-y-2">

    <% if (isLoggedIn) { %>

      <% if (userType === 'guest') { %>
        <a href="/explore" class="block px-4 py-2 rounded-xl hover:bg-gray-50">Explore</a>
        <a href="/store/favourite-home" class="block px-4 py-2 rounded-xl hover:bg-gray-50">Saved</a>
        <a href="/store/home-booking" class="block px-4 py-2 rounded-xl hover:bg-gray-50">Bookings</a>
      <% } %>

      <% if (userType === 'host') { %>
        <a href="/host/home-list" class="block px-4 py-2 rounded-xl hover:bg-gray-50">My Listings</a>
        <a href="/host/add-home" class="block px-4 py-2 rounded-xl hover:bg-gray-50">Add Home</a>
      <% } %>

      <form action="/logout" method="POST">
        <button class="text-rose-500 px-4 py-2">Logout</button>
      </form>

    <% } else { %>

      <a href="/" class="block px-4 py-2 rounded-xl hover:bg-gray-50">Home</a>
      <a href="/login" class="block px-4 py-2 rounded-xl hover:bg-gray-50">Login</a>
      <a href="/signup" class="block px-4 py-2 rounded-xl bg-gradient-to-r from-purple-500 to-rose-500 text-white text-center">
        Sign up
      </a>

    <% } %>

  </div>
</header>

<!-- 🔥 IMPORTANT FIX FOR OVERLAP -->
<div class="h-16"></div>

<script>
  document.getElementById('menuBtn').addEventListener('click', () => {
    document.getElementById('mobileMenu').classList.toggle('hidden');
  });

  const userMenuBtn = document.getElementById('userMenuBtn');
  const userDropdown = document.getElementById('userDropdown');
  const dropChevron = document.getElementById('dropChevron');

  if (userMenuBtn) {
    userMenuBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      userDropdown.classList.toggle('hidden');
      dropChevron.classList.toggle('rotate-180');
    });

    document.addEventListener('click', (e) => {
      if (!document.getElementById('userMenuWrapper').contains(e.target)) {
        userDropdown.classList.add('hidden');
        dropChevron.classList.remove('rotate-180');
      }
    });
  }
</script>