<header class="bg-white border-b border-gray-100 sticky top-0 z-50 shadow-sm">
  <nav class="container mx-auto flex justify-between items-center px-6 h-16">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-1.5 font-extrabold text-xl tracking-tight shrink-0">
      <span class="bg-gradient-to-r from-rose-500 to-orange-400 text-white w-8 h-8 rounded-xl flex items-center justify-center text-sm font-black shadow-sm">M</span>
      <span class="bg-gradient-to-r from-rose-500 to-orange-400 bg-clip-text text-transparent">MyHome</span>
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden md:flex items-center gap-1 text-sm font-medium text-gray-600">

      <% if (isLoggedIn) { %>

        <% if (userType === 'guest') { %>
          <li>
            <a href="/explore"
              class="px-4 py-2 rounded-full transition <%= currentPage==='explore' ? 'bg-red-50 text-red-500 font-semibold' : 'hover:bg-gray-100 text-gray-600' %>">
              Explore
            </a>
          </li>
          <li>
            <a href="/store/favourite-home"
              class="px-4 py-2 rounded-full transition flex items-center gap-1.5 <%= currentPage==='favourite' ? 'bg-red-50 text-red-500 font-semibold' : 'hover:bg-gray-100 text-gray-600' %>">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="<%= currentPage==='favourite' ? 'currentColor' : 'none' %>" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 016.364 0L12 7.636l1.318-1.318a4.5 4.5 0 116.364 6.364L12 20.364l-7.682-7.682a4.5 4.5 0 010-6.364z"/>
              </svg>
              Saved
            </a>
          </li>
          <li>
            <a href="/store/home-booking"
              class="px-4 py-2 rounded-full transition <%= currentPage==='bookingHome' ? 'bg-red-50 text-red-500 font-semibold' : 'hover:bg-gray-100 text-gray-600' %>">
              Bookings
            </a>
          </li>
        <% } %>

        <% if (userType === 'host') { %>
          <li>
            <a href="/host/home-list"
              class="px-4 py-2 rounded-full transition <%= currentPage==='homeList' ? 'bg-gray-100 text-gray-900 font-semibold' : 'hover:bg-gray-100 text-gray-600' %>">
              My Listings
            </a>
          </li>
          <li>
            <a href="/host/add-home"
              class="ml-1 px-4 py-2 rounded-full bg-red-500 hover:bg-red-600 text-white transition flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
              </svg>
              List a home
            </a>
          </li>
        <% } %>

        <!-- User dropdown -->
        <li class="ml-3 pl-3 border-l border-gray-200 relative" id="userMenuWrapper">
          <button id="userMenuBtn"
            class="flex items-center gap-2 bg-gray-50 border border-gray-200 hover:border-gray-300 rounded-full px-3 py-1.5 transition cursor-pointer">
            <div class="w-7 h-7 rounded-full bg-red-500 flex items-center justify-center text-white text-xs font-bold uppercase">
              <%= userName ? userName[0] : 'U' %>
            </div>
            <span class="text-gray-700 text-sm font-medium"><%= userName %></span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-gray-400 transition-transform duration-200" id="dropChevron" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>

          <!-- Dropdown panel -->
          <div id="userDropdown"
            class="hidden absolute right-0 mt-2 w-52 bg-white border border-gray-100 rounded-2xl shadow-xl py-2 z-50">

            <!-- User info -->
            <div class="px-4 py-3 border-b border-gray-100">
              <p class="text-sm font-semibold text-gray-800"><%= userName %></p>
              <p class="text-xs text-gray-400 capitalize mt-0.5"><%= userType %> account</p>
            </div>

            <!-- Guest links -->
            <% if (userType === 'guest') { %>
              <a href="/explore" class="flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-600 hover:bg-gray-50 transition">
                <span class="text-base">🔍</span> Explore
              </a>
              <a href="/store/favourite-home" class="flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-600 hover:bg-gray-50 transition">
                <span class="text-base">❤️</span> Saved homes
              </a>
              <a href="/store/home-booking" class="flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-600 hover:bg-gray-50 transition">
                <span class="text-base">📋</span> Bookings
              </a>
            <% } %>

            <!-- Host links -->
            <% if (userType === 'host') { %>
              <a href="/host/home-list" class="flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-600 hover:bg-gray-50 transition">
                <span class="text-base">🏠</span> My Listings
              </a>
              <a href="/host/add-home" class="flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-600 hover:bg-gray-50 transition">
                <span class="text-base">➕</span> List a home
              </a>
            <% } %>

            <!-- Logout -->
            <div class="border-t border-gray-100 mt-1 pt-1">
              <form action="/logout" method="POST">
                <button type="submit"
                  class="w-full flex items-center gap-2.5 px-4 py-2.5 text-sm text-red-500 hover:bg-red-50 transition text-left">
                  <span class="text-base">🚪</span> Log out
                </button>
              </form>
            </div>

          </div>
        </li>

      <% } else { %>

        <li>
          <a href="/"
            class="px-4 py-2 rounded-full transition <%= currentPage==='home' ? 'bg-red-50 text-red-500 font-semibold' : 'hover:bg-gray-100 text-gray-600' %>">
            Home
          </a>
        </li>
        <li>
          <a href="/login"
            class="px-4 py-2 rounded-full border border-gray-200 hover:border-gray-300 text-gray-600 transition">
            Log in
          </a>
        </li>
        <li>
          <a href="/signup"
            class="px-4 py-2 rounded-full bg-red-500 hover:bg-red-600 text-white transition shadow-sm">
            Sign up
          </a>
        </li>

      <% } %>

    </ul>

    <!-- Mobile hamburger -->
    <button id="menuBtn" class="md:hidden p-2 rounded-xl hover:bg-gray-100 transition text-gray-600">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>

  </nav>

  <!-- Mobile menu -->
  <div id="mobileMenu" class="hidden md:hidden border-t border-gray-100 bg-white px-6 py-4 space-y-1 text-sm font-medium text-gray-600">

    <% if (isLoggedIn) { %>

      <% if (userType === 'guest') { %>
        <a href="/explore" class="block px-4 py-2.5 rounded-xl hover:bg-gray-50 transition">Explore</a>
        <a href="/store/favourite-home" class="block px-4 py-2.5 rounded-xl hover:bg-gray-50 transition">❤️ Saved</a>
        <a href="/store/home-booking" class="block px-4 py-2.5 rounded-xl hover:bg-gray-50 transition">Bookings</a>
      <% } %>

      <% if (userType === 'host') { %>
        <a href="/host/home-list" class="block px-4 py-2.5 rounded-xl hover:bg-gray-50 transition">My Listings</a>
        <a href="/host/add-home" class="block px-4 py-2.5 rounded-xl hover:bg-gray-50 transition">+ List a home</a>
      <% } %>

      <div class="pt-2 border-t border-gray-100 flex items-center justify-between">
        <span class="text-gray-500">Hi, <strong><%= userName %></strong> · <span class="capitalize text-gray-400"><%= userType %></span></span>
        <form action="/logout" method="POST">
          <button type="submit" class="text-red-500 text-sm font-medium">Logout</button>
        </form>
      </div>

    <% } else { %>
      <a href="/" class="block px-4 py-2.5 rounded-xl hover:bg-gray-50 transition">Home</a>
      <a href="/login" class="block px-4 py-2.5 rounded-xl hover:bg-gray-50 transition">Log in</a>
      <a href="/signup" class="block px-4 py-2.5 rounded-xl bg-red-500 text-white text-center transition hover:bg-red-600">Sign up</a>
    <% } %>

  </div>
</header>

<script>
  // Mobile menu
  document.getElementById('menuBtn').addEventListener('click', () => {
    document.getElementById('mobileMenu').classList.toggle('hidden');
  });

  // User dropdown
  const userMenuBtn = document.getElementById('userMenuBtn');
  const userDropdown = document.getElementById('userDropdown');
  const dropChevron = document.getElementById('dropChevron');

  if (userMenuBtn) {
    userMenuBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      userDropdown.classList.toggle('hidden');
      dropChevron.classList.toggle('rotate-180');
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      if (!document.getElementById('userMenuWrapper').contains(e.target)) {
        userDropdown.classList.add('hidden');
        dropChevron.classList.remove('rotate-180');
      }
    });
  }
</script>
