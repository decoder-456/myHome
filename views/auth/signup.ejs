<%- include('../partials/head') %>
</head>

<body class="bg-gray-50">
  <%- include('../partials/nav') %>

  <main class="container mx-auto px-4 py-12 max-w-lg">

    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">

      <!-- Header -->
      <div class="text-center mb-8">
        <h1 class="text-2xl font-bold text-gray-900">Create your account</h1>
        <p class="text-gray-400 text-sm mt-1">Join AirBnB and start exploring</p>
      </div>

      <!-- 🔥 Helper for field errors -->
      <%
        const getError = (field) => {
          const error = errors.find(err => err.path === field);
          return error ? error.msg : null;
        };
      %>

      <!-- 🔥 Global Errors -->
      <% if (errors.length > 0) { %>
        <div class="mb-4 bg-red-50 border border-red-200 p-3 rounded-lg">
          <% errors.forEach(err => { %>
            <p class="text-red-500 text-sm"><%= err.msg %></p>
          <% }) %>
        </div>
      <% } %>

      <form action="/signup" method="POST" class="space-y-4">

        <!-- First & Last Name -->
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              First Name <span class="text-red-500">*</span>
            </label>
            <input type="text" name="firstName"
              value="<%= oldInput.firstName || '' %>"
              class="w-full px-4 py-2.5 border <%= getError('firstName') ? 'border-red-500' : 'border-gray-300' %> rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-red-400"/>

            <% if (getError('firstName')) { %>
              <p class="text-red-500 text-xs mt-1"><%= getError('firstName') %></p>
            <% } %>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Last Name <span class="text-red-500">*</span>
            </label>
            <input type="text" name="lastName"
              value="<%= oldInput.lastName || '' %>"
              class="w-full px-4 py-2.5 border <%= getError('lastName') ? 'border-red-500' : 'border-gray-300' %> rounded-xl text-sm"/>

            <% if (getError('lastName')) { %>
              <p class="text-red-500 text-xs mt-1"><%= getError('lastName') %></p>
            <% } %>
          </div>
        </div>

        <!-- Email -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Email <span class="text-red-500">*</span>
          </label>
          <input type="email" name="email"
            value="<%= oldInput.email || '' %>"
            class="w-full px-4 py-2.5 border <%= getError('email') ? 'border-red-500' : 'border-gray-300' %> rounded-xl text-sm"/>

          <% if (getError('email')) { %>
            <p class="text-red-500 text-xs mt-1"><%= getError('email') %></p>
          <% } %>
        </div>

        <!-- Password -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Password <span class="text-red-500">*</span>
          </label>
          <input type="password" name="password" id="password"
            class="w-full px-4 py-2.5 border <%= getError('password') ? 'border-red-500' : 'border-gray-300' %> rounded-xl text-sm"/>

          <% if (getError('password')) { %>
            <p class="text-red-500 text-xs mt-1"><%= getError('password') %></p>
          <% } %>
        </div>

        <!-- Confirm Password -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Confirm Password <span class="text-red-500">*</span>
          </label>
          <input type="password" name="confirmPassword" id="confirmPassword"
            class="w-full px-4 py-2.5 border <%= getError('confirmPassword') ? 'border-red-500' : 'border-gray-300' %> rounded-xl text-sm"/>

          <% if (getError('confirmPassword')) { %>
            <p class="text-red-500 text-xs mt-1"><%= getError('confirmPassword') %></p>
          <% } %>

          <p id="passwordError" class="text-red-500 text-xs mt-1 hidden">
            Passwords do not match
          </p>
        </div>

        <!-- User Type -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">
            I am a <span class="text-red-500">*</span>
          </label>

          <div class="grid grid-cols-2 gap-3">

            <label class="cursor-pointer">
              <input type="radio" name="userType" value="guest"
                <%= oldInput.userType === 'guest' ? 'checked' : '' %> />
              Guest
            </label>

            <label class="cursor-pointer">
              <input type="radio" name="userType" value="host"
                <%= oldInput.userType === 'host' ? 'checked' : '' %> />
              Host
            </label>

          </div>

          <% if (getError('userType')) { %>
            <p class="text-red-500 text-xs mt-1"><%= getError('userType') %></p>
          <% } %>
        </div>

        <!-- Terms -->
        <div class="flex items-start gap-3">
          <input type="checkbox" name="terms"
            <%= oldInput.terms ? 'checked' : '' %> />

          <label class="text-sm text-gray-500">
            I agree to Terms & Conditions
          </label>
        </div>

        <% if (getError('terms')) { %>
          <p class="text-red-500 text-xs"><%= getError('terms') %></p>
        <% } %>

        <!-- Submit -->
        <button type="submit"
          class="w-full bg-red-500 text-white py-3 rounded-xl">
          Create Account
        </button>

      </form>

    </div>

  </main>

  <script>
    const password = document.getElementById('password');
    const confirmPassword = document.getElementById('confirmPassword');
    const passwordError = document.getElementById('passwordError');

    function validatePasswords() {
      if (confirmPassword.value && password.value !== confirmPassword.value) {
        passwordError.classList.remove('hidden');
      } else {
        passwordError.classList.add('hidden');
      }
    }

    password.addEventListener('input', validatePasswords);
    confirmPassword.addEventListener('input', validatePasswords);
  </script>

</body>
</html>