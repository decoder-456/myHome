<%- include('../partials/head') %>
</head>

<body class="bg-gray-50 min-h-screen">
<%- include('../partials/nav') %>

<main class="container mx-auto px-6 py-10">

  <div class="flex justify-between items-end mb-10">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">My Listings</h1>
      <p class="text-gray-400 text-sm mt-1">
        <% if (homes.length > 0) { %>
          You have <span class="font-semibold text-gray-600"><%= homes.length %></span> home<%= homes.length !== 1 ? 's' : '' %> listed
        <% } else { %>
          No homes listed yet
        <% } %>
      </p>
    </div>
    <a href="/host/add-home"
      class="bg-gradient-to-r from-red-500 to-rose-500 hover:from-red-600 hover:to-rose-600 text-white px-5 py-2.5 rounded-2xl text-sm font-semibold transition shadow-md flex items-center gap-2">
      + Add New Listing
    </a>
  </div>

  <% if (homes.length === 0) { %>
    <div class="text-center py-28 text-gray-300">
      <p class="text-7xl mb-5">🏚️</p>
      <p class="text-xl font-medium text-gray-400 mb-2">You haven't listed any homes yet</p>
      <p class="text-sm text-gray-300 mb-8">Start earning by sharing your space</p>
      <a href="/host/add-home"
        class="inline-block bg-red-500 hover:bg-red-600 text-white px-6 py-3 rounded-2xl text-sm font-semibold transition shadow-sm">
        List your first home
      </a>
    </div>
  <% } else { %>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <% homes.forEach(home => { %>

      <div class="bg-white rounded-3xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300 group">

        <div class="overflow-hidden relative">
          <img src="<%= home.photoUrl %>" alt="<%= home.houseName %>"
            class="w-full h-52 object-cover group-hover:scale-105 transition duration-500">
          <div class="absolute top-3 left-3">
            <span class="bg-white/90 backdrop-blur-sm text-gray-700 text-xs font-semibold px-2.5 py-1 rounded-full shadow-sm">
              ⭐ <%= home.rating %>
            </span>
          </div>
        </div>

        <div class="p-5">
          <h3 class="text-base font-bold text-gray-900 truncate mb-1"><%= home.houseName %></h3>
          <p class="text-gray-400 text-sm truncate mb-1">📍 <%= home.location %></p>
          <p class="text-red-500 font-bold text-base mb-5">
            ₹<%= home.price %> <span class="text-gray-400 font-normal text-xs">/ night</span>
          </p>

          <div class="flex gap-2">
            <a href="/add-home/<%= home._id %>?editing=true"
              class="flex-1 text-center bg-gray-50 hover:bg-gray-100 border border-gray-200 text-gray-700 py-2.5 rounded-xl text-sm font-medium transition">
              ✏️ Edit
            </a>
            <form action="/host/delete-home/<%= home._id %>" method="POST" class="flex-1">
              <button type="submit"
                class="w-full bg-red-50 hover:bg-red-100 border border-red-100 text-red-500 py-2.5 rounded-xl text-sm font-medium transition">
                🗑️ Delete
              </button>
            </form>
          </div>
        </div>

      </div>

    <% }) %>
  </div>

  <% } %>

</main>
</body>
</html>
