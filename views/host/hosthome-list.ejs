<%- include('../partials/head') %>
</head>

<body class="min-h-screen bg-gradient-to-br from-purple-50 via-rose-50 to-orange-50">

<%- include('../partials/nav') %>

<main class="container mx-auto px-6 py-12">

  <!-- Heading -->
  <div class="text-center mb-12">
    <h2 class="text-4xl font-bold text-gray-900 tracking-tight">
      🏡 Your Listings
    </h2>
    <p class="text-gray-500 mt-2 text-sm">
      Manage and explore your hosted homes
    </p>
  </div>

  <!-- Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10">

    <% homes.forEach(home => { %>

    <div class="bg-white/80 backdrop-blur-lg rounded-3xl shadow-xl border border-gray-100 overflow-hidden 
                hover:shadow-2xl transition duration-300 transform hover:-translate-y-2 group">

      <!-- Image -->
      <div class="relative overflow-hidden">
        <img 
          src="<%= home.photoUrl || 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6' %>"
          class="w-full h-56 object-cover group-hover:scale-110 transition duration-500">

        <!-- Overlay gradient -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
      </div>

      <!-- Content -->
      <div class="p-5">

        <h3 class="text-xl font-semibold text-gray-800 mb-2 group-hover:text-purple-600 transition">
          <%= home.houseName %>
        </h3>

        <p class="text-gray-500 text-sm mb-4">
          📍 <%= home.location %>
        </p>

        <div class="flex justify-between items-center">

          <!-- Price -->
          <span class="text-lg font-bold text-purple-600">
            ₹<%= home.price %>
            <span class="text-gray-400 text-sm">/ night</span>
          </span>

          <!-- Rating -->
          <div class="flex items-center text-yellow-400 font-semibold text-sm">
            ⭐ <span class="text-gray-700 ml-1"><%= home.rating %></span>
          </div>

        </div>

      </div>

      <!-- Actions -->
      <div class="flex gap-3 px-5 pb-5">

        <a href="/add-home/<%= home.id %>?editing=true"
           class="flex-1 text-center py-2.5 rounded-xl text-sm font-semibold text-white 
                  bg-gradient-to-r from-blue-500 to-indigo-500 hover:opacity-90 transition shadow">
          Edit
        </a>

        <form action="/host/delete-home/<%= home.id %>" method="POST" class="flex-1">
          <button 
            class="w-full py-2.5 rounded-xl text-sm font-semibold text-white 
                   bg-gradient-to-r from-rose-500 to-red-500 hover:opacity-90 transition shadow">
            Delete
          </button>
        </form>

      </div>

    </div>

    <% }) %>

  </div>

  <!-- Empty State -->
  <% if (homes.length === 0) { %>
    <div class="text-center mt-16">
      <p class="text-gray-400 text-lg">No homes listed yet</p>
      <a href="/host/add-home"
        class="inline-block mt-4 px-6 py-3 rounded-xl bg-gradient-to-r from-purple-500 to-rose-500 text-white font-semibold shadow hover:opacity-90 transition">
        Add Your First Home
      </a>
    </div>
  <% } %>

</main>

</body>
</html>