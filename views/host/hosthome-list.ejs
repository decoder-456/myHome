<%- include('../partials/head') %>
</head>

<body class="bg-gray-50 min-h-screen">
<%- include('../partials/nav') %>

<!-- Header Banner -->
<div class="py-10 px-6 border-b border-orange-100" style="background: linear-gradient(135deg,#fff7ed 0%,#fef3c7 100%);">
  <div class="container mx-auto max-w-6xl flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-3xl font-extrabold text-gray-900">My Listings</h1>
      <p class="text-gray-500 text-sm mt-1">
        <% if (homes.length > 0) { %>
          <span class="font-semibold text-gray-700"><%= homes.length %></span>
          home<%= homes.length !== 1 ? 's' : '' %> listed
        <% } else { %>
          No homes listed yet
        <% } %>
      </p>
    </div>
    <a href="/host/add-home"
      class="inline-flex items-center gap-2 text-white px-5 py-2.5 rounded-2xl text-sm font-semibold shadow-md hover:opacity-90 transition self-start sm:self-auto"
      style="background: linear-gradient(135deg,#e11d48,#f97316);">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
      </svg>
      Add New Listing
    </a>
  </div>
</div>

<main class="container mx-auto px-6 py-10 max-w-6xl">

  <!-- Empty State -->
  <% if (homes.length === 0) { %>
    <div class="flex flex-col items-center justify-center py-28 text-center">
      <div class="w-24 h-24 rounded-3xl flex items-center justify-center text-4xl mb-6"
        style="background: linear-gradient(135deg,#fff1f2,#fff7ed);">
        🏚️
      </div>
      <p class="text-xl font-semibold text-gray-700 mb-2">No listings yet</p>
      <p class="text-sm text-gray-400 mb-8 max-w-xs">Start earning by sharing your space with travellers around the world.</p>
      <a href="/host/add-home"
        class="text-white px-6 py-3 rounded-2xl text-sm font-semibold shadow-md hover:opacity-90 transition"
        style="background: linear-gradient(135deg,#e11d48,#f97316);">
        List your first home
      </a>
    </div>

  <% } else { %>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <% homes.forEach(home => { %>

      <div class="bg-white rounded-3xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300 group flex flex-col">

        <!-- Image -->
        <div class="relative overflow-hidden h-52 shrink-0">
          <img src="<%= home.photoUrl %>" alt="<%= home.houseName %>"
            class="w-full h-full object-cover group-hover:scale-105 transition duration-500">
          <span class="absolute top-3 left-3 bg-white/95 text-amber-500 text-xs font-bold px-2.5 py-1 rounded-full shadow-sm">
            ⭐ <%= home.rating %>
          </span>
          <span class="absolute bottom-3 right-3 text-white text-xs font-bold px-3 py-1.5 rounded-full shadow"
            style="background:rgba(225,29,72,0.85); backdrop-filter:blur(4px);">
            ₹<%= home.price %>/night
          </span>
        </div>

        <!-- Content -->
        <div class="p-5 flex flex-col flex-1">
          <h3 class="text-base font-bold text-gray-900 truncate mb-1"><%= home.houseName %></h3>
          <p class="text-gray-400 text-sm truncate mb-3">📍 <%= home.location %></p>

          <% if (home.description) { %>
            <p class="text-gray-500 text-xs leading-relaxed mb-4 line-clamp-2"><%= home.description %></p>
          <% } %>

          <!-- Actions -->
          <div class="flex gap-2 mt-auto">
            <a href="/add-home/<%= home._id %>?editing=true"
              class="flex-1 text-center bg-gray-50 hover:bg-gray-100 border border-gray-200 text-gray-700 py-2.5 rounded-xl text-sm font-medium transition flex items-center justify-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
              Edit
            </a>
            <form action="/host/delete-home/<%= home._id %>" method="POST" class="flex-1"
              onsubmit="return confirm('Delete this listing?')">
              <button type="submit"
                class="w-full bg-rose-50 hover:bg-rose-100 border border-rose-200 text-rose-600 py-2.5 rounded-xl text-sm font-medium transition flex items-center justify-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
                Delete
              </button>
            </form>
          </div>
        </div>

      </div>

    <% }) %>
  </div>

  <% } %>

</main>
</body>
</html>
