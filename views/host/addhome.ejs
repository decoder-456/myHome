<%- include('../partials/head') %>
</head>

<body class="min-h-screen bg-gradient-to-br from-purple-50 via-rose-50 to-orange-50">

<%- include('../partials/nav') %>

<!-- Header -->
<div class="py-12 px-6 border-b border-gray-100 bg-white/60 backdrop-blur-md">
  <div class="container mx-auto max-w-2xl">

    <a href="/host/home-list"
      class="text-sm text-gray-400 hover:text-gray-600 transition flex items-center gap-2 mb-4">
      ← Back to listings
    </a>

    <h1 class="text-4xl font-bold text-gray-900 tracking-tight">
      <%= editing ? "Edit your listing ✏️" : "List your home 🏡" %>
    </h1>

    <p class="text-gray-500 text-sm mt-2">
      <%= editing ? "Update your listing details easily." : "Share your space with travelers around the world." %>
    </p>

  </div>
</div>

<main class="container mx-auto px-4 py-12 max-w-2xl">

  <!-- Card -->
  <div class="bg-white/80 backdrop-blur-lg rounded-3xl shadow-2xl border border-gray-100 p-8">

    <form action="<%= editing ? '/edit-home' : '/add-home' %>"
          method="POST"
          enctype="multipart/form-data"
          class="space-y-6">

      <% if (editing) { %>
        <input type="hidden" name="id" value="<%= home._id %>">
      <% } %>

      <!-- House Name -->
      <div>
        <label class="block text-sm font-medium text-gray-600 mb-1">
          House Name
        </label>
        <input type="text" name="houseName"
          value="<%= editing ? home.houseName : '' %>" required
          placeholder="Cozy Beach House in Goa"
          class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-purple-400 outline-none transition"/>
      </div>

      <!-- Location -->
      <div>
        <label class="block text-sm font-medium text-gray-600 mb-1">
          Location
        </label>
        <input type="text" name="location"
          value="<%= editing ? home.location : '' %>" required
          placeholder="Goa, India"
          class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-purple-400 outline-none transition"/>
      </div>

      <!-- Price & Rating -->
      <div class="grid grid-cols-2 gap-4">

        <div>
          <label class="block text-sm font-medium text-gray-600 mb-1">
            Price / Night
          </label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">₹</span>
            <input type="number" name="price"
              value="<%= editing ? home.price : '' %>" required min="1"
              class="w-full pl-8 pr-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-purple-400 outline-none"/>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-600 mb-1">
            Rating
          </label>
          <input type="number" name="rating"
            value="<%= editing ? home.rating : '' %>" required min="0" max="5" step="0.1"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-purple-400 outline-none"/>
        </div>

      </div>

      <!-- Photo -->
      <div>
        <label class="block text-sm font-medium text-gray-600 mb-2">
          Photo
        </label>

        <% if (editing && home.photoUrl) { %>
          <img src="<%= home.photoUrl %>"
            class="h-40 w-full object-cover rounded-xl mb-3 shadow-sm border"/>
        <% } %>

        <input type="file" name="photoUrl"
          accept="image/jpeg,image/jpg,image/png"
          <%= editing ? '' : 'required' %>
          class="w-full px-4 py-2 border border-gray-200 rounded-xl bg-gray-50 focus:ring-2 focus:ring-purple-400 file:mr-3 file:px-3 file:py-1 file:rounded-lg file:bg-purple-50 file:text-purple-600"/>
      </div>

      <!-- Description -->
      <div>
        <label class="block text-sm font-medium text-gray-600 mb-1">
          Description
        </label>
        <textarea name="description" rows="4"
          placeholder="What makes your place special?"
          class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-purple-400 outline-none resize-none"><%= editing ? home.description : '' %></textarea>
      </div>

      <!-- Submit -->
      <button type="submit"
        class="w-full py-3.5 rounded-xl text-white font-semibold bg-gradient-to-r from-purple-500 via-rose-500 to-orange-400 hover:opacity-90 active:scale-[0.98] transition shadow-lg">
        <%= editing ? "Save Changes" : "Publish Listing" %>
      </button>

    </form>

  </div>

</main>

</body>
</html>