<%- include('../partials/head') %>
</head>

<body class="bg-gray-50 min-h-screen">
<%- include('../partials/nav') %>

<main class="container mx-auto px-4 py-12 max-w-2xl">

  <!-- Header -->
  <div class="mb-8">
    <a href="/host/home-list"
       class="text-sm text-gray-400 hover:text-gray-600 transition flex items-center gap-1 mb-4">
       ← Back to listings
    </a>

    <h1 class="text-3xl font-bold text-gray-900">
      <%= editing ? "Edit listing" : "List your home" %>
    </h1>

    <p class="text-gray-400 text-sm mt-1">
      <%= editing ? "Update your listing details." : "Share your space with travellers." %>
    </p>
  </div>

  <!-- Form Card -->
  <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8">

    <!-- ✅ IMPORTANT: enctype added -->
    <form action="<%= editing ? '/edit-home' : '/add-home' %>"
          method="POST"
          enctype="multipart/form-data"
          class="space-y-5">

      <% if (editing) { %>
        <input type="hidden" name="id" value="<%= home._id %>">
      <% } %>

      <!-- House Name -->
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1.5">
          House Name <span class="text-red-400">*</span>
        </label>

        <input type="text"
               name="houseName"
               value="<%= editing ? home.houseName : '' %>"
               required
               placeholder="e.g. Cozy Beach House in Goa"
               class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-red-400 transition"/>
      </div>

      <!-- Location -->
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1.5">
          Location <span class="text-red-400">*</span>
        </label>

        <input type="text"
               name="location"
               value="<%= editing ? home.location : '' %>"
               required
               placeholder="e.g. Goa, India"
               class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-red-400 transition"/>
      </div>

      <!-- Price & Rating -->
      <div class="grid grid-cols-2 gap-4">

        <!-- Price -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">
            Price / Night <span class="text-red-400">*</span>
          </label>

          <div class="relative">
            <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 text-sm">₹</span>

            <input type="number"
                   name="price"
                   value="<%= editing ? home.price : '' %>"
                   required
                   min="1"
                   class="w-full pl-8 pr-4 py-3 border border-gray-200 rounded-xl text-sm bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-red-400"/>
          </div>
        </div>

        <!-- Rating -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">
            Rating (0–5) <span class="text-red-400">*</span>
          </label>

          <input type="number"
                 name="rating"
                 value="<%= editing ? home.rating : '' %>"
                 required
                 min="0"
                 max="5"
                 step="0.1"
                 class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-red-400"/>
        </div>

      </div>

      <!-- Photo Upload -->
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1.5">
          Photo <span class="text-red-400">*</span>
        </label>

        <!-- Show existing image if editing -->
        <% if (editing && home.photoUrl) { %>
          <div class="mb-2">
            <img src="<%= home.photoUrl %>"
                 alt="Current photo"
                 class="h-32 w-full object-cover rounded-xl border border-gray-200"/>
            <p class="text-xs text-gray-400 mt-1">
              Upload new image to replace
            </p>
          </div>
        <% } %>

        <!-- ✅ ONLY ONE FILE INPUT -->
        <input type="file"
               name="photoUrl"
               accept="image/jpeg,image/jpg,image/png"
               <%= editing ? '' : 'required' %>
               class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-red-400"/>
      </div>

      <!-- Description -->
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1.5">
          Description
        </label>

        <textarea name="description"
                  rows="4"
                  placeholder="Describe what makes your place special..."
                  class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-red-400 resize-none"><%= editing ? home.description : '' %></textarea>
      </div>

      <!-- Submit -->
      <button type="submit"
        class="w-full bg-gradient-to-r from-red-500 to-rose-500 hover:from-red-600 hover:to-rose-600 text-white py-3.5 rounded-2xl font-semibold text-sm shadow-md">
        <%= editing ? "Save Changes" : "Publish Listing" %>
      </button>

    </form>
  </div>

</main>
</body>
</html>